APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/calorie_food
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=calorie-food
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

TELEGRAM_BOT_TOKEN=replace_with_token
TELEGRAM_INITDATA_TTL_SECONDS=300
TELEGRAM_ALLOW_INSECURE_DEV=1
AUTH_RATE_LIMIT_PER_MINUTE=30
SCANS_RATE_LIMIT_PER_MINUTE=20

AI_PROVIDER=openai
AI_MODEL_VISION=gpt-4.1-mini
AI_REQUEST_TIMEOUT_MS=30000
APP_NAME=calorie-food-miniapp
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=45

MAX_UPLOAD_MB=8
ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp
