POSTGRES_DB=calorie_food
POSTGRES_USER=calorie_user
POSTGRES_PASSWORD=change_me_strong_password

APP_ENV=production
APP_PORT=8080
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=45
APP_NAME=calorie-food-miniapp

TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_INITDATA_TTL_SECONDS=300
TELEGRAM_ALLOW_INSECURE_DEV=0

AUTH_RATE_LIMIT_PER_MINUTE=30
SCANS_RATE_LIMIT_PER_MINUTE=20
LOG_LEVEL=INFO
MAINTENANCE_CLEANUP_INTERVAL_MINUTES=30
SESSIONS_RETENTION_DAYS=30
SCAN_JOBS_RETENTION_DAYS=30

CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\\.)*your-domain\\.com$|^https://([a-z0-9-]+\\.)*telegram\\.org$|^https://([a-z0-9-]+\\.)*t\\.me$
